{
	"name": "vigorous-virgo",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"telegram:session": "node scripts/telegram/generate-session.js",
		"telegram:export:all": "node scripts/telegram/export-channel-posts.js --all --output .telegram-export",
		"telegram:export:week": "node scripts/telegram/export-channel-posts.js --days 7 --output .telegram-export",
		"telegram:convert": "node scripts/telegram/convert-export-to-markdown.js --input .telegram-export",
		"telegram:sync:bootstrap": "node scripts/telegram/sync-to-astro.js --mode bootstrap",
		"telegram:sync:week": "node scripts/telegram/sync-to-astro.js --mode week --days 7",
		"telegram:pipeline:bootstrap": "npm run telegram:export:all && npm run telegram:convert && npm run telegram:sync:bootstrap",
		"telegram:pipeline:week": "npm run telegram:export:week && npm run telegram:convert && npm run telegram:sync:week"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.4",
		"@astrojs/mdx": "^4.0.2",
		"@astrojs/react": "^4.1.0",
		"@astrojs/rss": "^4.0.10",
		"@astrojs/sitemap": "^3.2.1",
		"@astrojs/tailwind": "^5.1.3",
		"@types/react": "^18.2.45",
		"@types/react-dom": "^18.2.18",
		"@vercel/analytics": "^1.2.2",
		"astro": "^5.0.5",
		"astro-yandex-metrika": "^1.0.1",
		"canvas-confetti": "^1.9.2",
		"mdast-util-to-string": "^4.0.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"reading-time": "^1.5.0",
		"rehype-pretty-code": "^0.13.0",
		"tailwindcss": "^3.4.0",
		"typescript": "^5.3.3"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.10",
		"prettier": "^3.1.1",
		"prettier-plugin-astro": "^0.14.0",
		"prettier-plugin-tailwindcss": "^0.6.0",
		"telegram": "^2.26.22"
	}
}