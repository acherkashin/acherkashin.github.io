---
import { AppConfig } from '@/utils/AppConfig';
import Base from '@/layouts/Base.astro';
// import Hero from '@/components/Hero.astro';
import LatestPosts from '@/components/LatestPosts.astro';
import LatestTelegramPosts from '@/components/LatestTelegramPosts.astro';
import AllProjects from '@/components/AllProjects.astro';
import { sortPostsByDate } from '@/utils/data.util';
import { MarkdownInstance, MDXInstance } from 'astro';
import Snowfall from '@/components/Snowfall.astro';

const { title } = AppConfig;
const { description } = AppConfig;

const allPosts = await Astro.glob<MDXInstance<any> | MarkdownInstance<any>>(
'./articles/*.(md|mdx)'
);
allPosts.sort(sortPostsByDate);
const latestPosts = allPosts.slice(0, 3);

// Load Telegram posts
const telegramPosts = await Astro.glob('./posts/*.md');
telegramPosts.sort((a, b) => {
  const dateA = new Date(a.frontmatter.publishDate);
  const dateB = new Date(b.frontmatter.publishDate);
  return dateB.getTime() - dateA.getTime();
});
const latestTelegramPosts = telegramPosts.slice(0, 3);
---

<Base head={{ title, description }}>
<!-- <Hero /> -->
<LatestPosts posts={latestPosts} />
{latestTelegramPosts.length > 0 && (
  <LatestTelegramPosts posts={latestTelegramPosts} />
)}
<AllProjects />
<Snowfall count={120}/>
</Base>
