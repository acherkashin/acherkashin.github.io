---
import { AppConfig } from '@/utils/AppConfig';
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import Heading from '@/components/Heading.astro';
import DemoCard from '@/components/DemoCard.astro';
import { playgrounds } from '@/utils/playgrounds';

const { title } = AppConfig;
const pageTitle = `Демо - ${title}`;
const pageDescription = 'Коллекция интерактивных демо и playground-страниц';
---

<Base head={{ title: pageTitle, description: pageDescription }}>
	<Section>
		<Heading title="Демо" />
	</Section>
	<Section>
		<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
			{
				playgrounds.map((playground) => (
					<div class="h-full">
						<DemoCard playground={playground} />
					</div>
				))
			}
		</div>
	</Section>
</Base>
