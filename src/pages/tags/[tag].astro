---
import Section from '@/components/Section.astro';
import Card from '@/components/Card.astro';
import Base from '@/layouts/Base.astro';
import Heading from '@/components/Heading.astro';
import TelegramPostCard from '@/components/TelegramPostCard.astro';
import { AppConfig } from '@/utils/AppConfig';
import { extractTelegramTagsFromMarkdown } from '@/utils/telegram-tags.util';
import { MarkdownInstance, MDXInstance } from 'astro';

export async function getStaticPaths(): Promise<any> {
	const articlePosts = await Astro.glob<MDXInstance<any> | MarkdownInstance<any>>('../articles/*.(md|mdx)');
	const telegramPosts = await Astro.glob<MarkdownInstance<any>>('../posts/*.md');

	const tagsMap = new Map<
		string,
		{
			articles: Array<MDXInstance<any> | MarkdownInstance<any>>;
			telegram: Array<MarkdownInstance<any>>;
		}
	>();

	const ensureTagEntry = (tag: string) => {
		const existing = tagsMap.get(tag);
		if (existing) return existing;
		const created = { articles: [], telegram: [] } as {
			articles: Array<MDXInstance<any> | MarkdownInstance<any>>;
			telegram: Array<MarkdownInstance<any>>;
		};
		tagsMap.set(tag, created);
		return created;
	};

	for (const post of articlePosts) {
		const tags = Array.isArray(post.frontmatter.tags) ? post.frontmatter.tags : [];
		for (const rawTag of tags) {
			if (typeof rawTag !== 'string') continue;
			const tag = rawTag.trim().toLowerCase();
			if (!tag) continue;
			ensureTagEntry(tag).articles.push(post);
		}
	}

	for (const post of telegramPosts) {
		const frontmatter = post.frontmatter as unknown as Record<string, unknown>;
		const archiveTags = frontmatter.archiveTags;
		const tags = Array.isArray(archiveTags)
			? archiveTags.filter((rawTag: unknown): rawTag is string => typeof rawTag === 'string')
			: extractTelegramTagsFromMarkdown(typeof post.rawContent === 'function' ? post.rawContent() : '');
		for (const tag of tags) {
			ensureTagEntry(tag).telegram.push(post);
		}
	}

	return [...tagsMap.entries()].map(([tag, value]) => ({
		params: { tag },
		props: {
			articles: value.articles,
			telegramPosts: value.telegram
		}
	}));
}

interface Props {
	articles: Array<MDXInstance<any> | MarkdownInstance<any>>;
	telegramPosts: Array<MarkdownInstance<any>>;
}

const { tag: rawTag = '' } = Astro.params as { tag?: string };
const tag = rawTag.toLowerCase();
const title = AppConfig.title;
const description = AppConfig.description;
const VIDEO_MEDIA_RE = /\.(mp4|mov|webm|m4v|ogg)(?:[?#].*)?$/i;

const { articles, telegramPosts } = Astro.props as Props;
const taggedItems = [
	...articles.map((post) => ({
		type: 'article' as const,
		post,
		publishDate: post.frontmatter.pubDate
	})),
	...telegramPosts.map((post) => ({
		type: 'telegram' as const,
		post,
		publishDate: post.frontmatter.publishDate
	}))
].sort((a, b) => {
	const aDate = new Date(a.publishDate || '').getTime();
	const bDate = new Date(b.publishDate || '').getTime();
	return bDate - aDate;
});

let telegramImageIndex = 0;
const taggedItemsWithImagePriority = taggedItems.map((item) => {
	if (item.type !== 'telegram') {
		return { ...item, imageIndex: Number.POSITIVE_INFINITY };
	}

	const mediaList = Array.isArray(item.post.frontmatter.media) ? item.post.frontmatter.media : [];
	const hasArchiveImage =
		typeof item.post.frontmatter?.archiveImage?.src === 'string' ||
		mediaList.some((src: string) => !VIDEO_MEDIA_RE.test(src));

	return {
		...item,
		imageIndex: hasArchiveImage ? telegramImageIndex++ : Number.POSITIVE_INFINITY
	};
});
---

<Base head={{ title, description }}>
	<Section>
		<Heading title={`Материалы с тегом #${tag}`} />
	</Section>
	<Section>
		{
			taggedItemsWithImagePriority.map((item) => (
				<div class="mb-4 basis-1 last:mb-0">
					{item.type === 'article' ? <Card post={item.post} /> : <TelegramPostCard post={item.post} index={item.imageIndex} />}
				</div>
			))
		}
	</Section>
</Base>
