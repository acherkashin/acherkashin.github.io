---
interface Props {
	src: string;
	alt?: string;
}

const { src, alt } = Astro.props;
---

<figure class="flex flex-col items-center">
	<img
		src={src}
		title={alt}
		alt={alt}
		data-article-image-trigger
		tabindex="0"
		aria-haspopup="dialog"
		class="cursor-zoom-in"
	/>
	<figcaption>{alt}</figcaption>
</figure>
