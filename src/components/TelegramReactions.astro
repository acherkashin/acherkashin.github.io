---
import SvgIcon from './SvgIcon.astro';

interface Reaction {
  reaction: string;
  count: number;
  chosenOrder?: number | null;
}

interface Props {
  reactions: Reaction[];
  views?: number | null;
  forwards?: number | null;
  comments?: number | null;
  className?: string;
}

const { reactions, views, forwards, comments, className = '' } = Astro.props;
const normalizedComments = Number(comments);
const hasComments =
  comments !== null && comments !== undefined && Number.isFinite(normalizedComments);
const hasViews = typeof views === 'number' && Number.isFinite(views) && views > 0;
const hasForwards = typeof forwards === 'number' && Number.isFinite(forwards) && forwards > 0;

// Filter out unknown reactions and sort by count
const displayReactions = reactions
  .filter(r => r.reaction !== 'unknown')
  .sort((a, b) => b.count - a.count);
---

<div class={`flex flex-wrap items-center gap-2 text-sm ${className}`}>
  {displayReactions.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {displayReactions.map((r) => (
        <span class="inline-flex items-center gap-1 rounded-xl bg-stone-600 px-3 py-1 text-xs font-bold text-white">
          <span class="text-base leading-none">{r.reaction}</span>
          <span>{r.count}</span>
        </span>
      ))}
    </div>
  )}
  
  {(hasViews || hasForwards || hasComments) && (
    <div class="flex items-center gap-3 text-xs text-stone-600 dark:text-stone-400">
      {hasViews && (
        <span class="flex items-center gap-1">
          <SvgIcon name="eye" className="h-4 w-4" />
          <span>{views.toLocaleString('ru-RU')}</span>
        </span>
      )}
      {hasForwards && (
        <span class="flex items-center gap-1">
          <SvgIcon name="share" className="h-4 w-4" />
          <span>{forwards.toLocaleString('ru-RU')}</span>
        </span>
      )}
      {hasComments && (
        <span class="flex items-center gap-1">
          <SvgIcon name="comment" className="h-4 w-4" />
          <span>{normalizedComments.toLocaleString('ru-RU')}</span>
        </span>
      )}
    </div>
  )}
</div>
