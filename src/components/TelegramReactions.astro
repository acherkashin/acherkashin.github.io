---
interface Reaction {
  reaction: string;
  count: number;
  chosenOrder?: number | null;
}

interface Props {
  reactions: Reaction[];
  views?: number | null;
  forwards?: number | null;
  className?: string;
}

const { reactions, views, forwards, className = '' } = Astro.props;

// Filter out unknown reactions and sort by count
const displayReactions = reactions
  .filter(r => r.reaction !== 'unknown')
  .sort((a, b) => b.count - a.count);

const totalReactions = reactions.reduce((sum, r) => sum + r.count, 0);
---

<div class={`flex flex-wrap items-center gap-2 text-sm ${className}`}>
  {displayReactions.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {displayReactions.map((r) => (
        <span class="inline-flex items-center gap-1 rounded-full bg-stone-300/80 px-2.5 py-1 text-xs font-medium text-stone-700 dark:bg-stone-700/80 dark:text-stone-300">
          <span class="text-base leading-none">{r.reaction}</span>
          <span>{r.count}</span>
        </span>
      ))}
    </div>
  )}
  
  {(views || forwards) && (
    <div class="flex items-center gap-3 text-xs text-stone-600 dark:text-stone-400">
      {views && (
        <span class="flex items-center gap-1">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <span>{views.toLocaleString('ru-RU')}</span>
        </span>
      )}
      {forwards && (
        <span class="flex items-center gap-1">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          <span>{forwards.toLocaleString('ru-RU')}</span>
        </span>
      )}
    </div>
  )}
</div>