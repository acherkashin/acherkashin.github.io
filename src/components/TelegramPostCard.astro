---
import { formatDate } from '@/utils/data.util';
import { buildTextPreview } from '@/utils/markdown-text.util';
import { extractTelegramTagsFromMarkdown } from '@/utils/telegram-tags.util';
import TelegramReactions from './TelegramReactions.astro';
import Tags from './Tags.astro';
import SvgIcon from './SvgIcon.astro';

interface Props {
  post: any;
  index?: number;
}

const { post, index = Number.POSITIVE_INFINITY } = Astro.props;
const rawPostContent = typeof post.rawContent === 'function' ? post.rawContent() : '';
const textPreview =
  (typeof post.frontmatter.archiveExcerpt === 'string' && post.frontmatter.archiveExcerpt.trim()) ||
  buildTextPreview(rawPostContent, 250) ||
  post.frontmatter.title ||
  '';
const postTags = Array.isArray(post.frontmatter.archiveTags)
  ? post.frontmatter.archiveTags.filter((tag: unknown): tag is string => typeof tag === 'string')
  : extractTelegramTagsFromMarkdown(rawPostContent);

const mediaList: string[] = Array.isArray(post.frontmatter.media) ? post.frontmatter.media : [];
const mediaCount = mediaList.length;
const isVideoMedia = (src: string) => /\.(mp4|mov|webm|m4v|ogg)(?:[?#].*)?$/i.test(src);
const archiveImage =
  post.frontmatter.archiveImage &&
  typeof post.frontmatter.archiveImage === 'object' &&
  typeof post.frontmatter.archiveImage.src === 'string' &&
  Number.isFinite(Number(post.frontmatter.archiveImage.width)) &&
  Number.isFinite(Number(post.frontmatter.archiveImage.height))
    ? {
        src: String(post.frontmatter.archiveImage.src),
        width: Number(post.frontmatter.archiveImage.width),
        height: Number(post.frontmatter.archiveImage.height),
      }
    : null;
const previewImage = archiveImage?.src ?? mediaList.find((src) => !isVideoMedia(src));
const hasPreviewImage = Boolean(previewImage);
const previewImageWidth = archiveImage?.width;
const previewImageHeight = archiveImage?.height;
const shouldPrioritizeImage = hasPreviewImage && index < 2;
const hasViews = Boolean(post.frontmatter.views);
const viewsCount = Number(post.frontmatter.views);
const commentsCount = Number(post.frontmatter.comments);
const hasComments =
  post.frontmatter.comments !== null &&
  post.frontmatter.comments !== undefined &&
  Number.isFinite(commentsCount);
const reactions = post.frontmatter.reactions || [];
const hasReactions = reactions.length > 0 && reactions.some((r: any) => r.count > 0);
---

<a href={post.url} class="group block h-full">
  <div
    class="flex h-full flex-col overflow-hidden rounded-2xl bg-stone-200/50 from-orange-900 via-amber-700 to-white p-[1px] shadow-[inset_0_0_0_1px_rgba(255,255,255,0.4)] transition-all hover:bg-gradient-to-r dark:bg-gray-900"
  >
    <div
      class="flex h-full flex-col rounded-[1rem] bg-stone-300 text-gray-900 opacity-90 dark:bg-stone-800 dark:text-white"
    >
      {hasPreviewImage && previewImage && (
        <div class="relative overflow-hidden rounded-t-[1rem]">
          <img
            src={previewImage}
            alt="Post preview"
            class="h-48 w-full object-cover transition-transform group-hover:scale-105"
            loading={shouldPrioritizeImage ? 'eager' : 'lazy'}
            fetchpriority={index === 0 ? 'high' : undefined}
            decoding="async"
            width={previewImageWidth}
            height={previewImageHeight}
          />
          {mediaCount > 1 && (
            <div class="absolute right-2 top-2 rounded-full bg-black/60 px-2 py-1 text-xs font-medium text-white backdrop-blur-sm">
              +{mediaCount - 1}
            </div>
          )}
        </div>
      )}

      <div class="flex flex-1 flex-col p-4">
        <div class="flex-1">
          <div class="mb-3 flex justify-between text-xs text-stone-600 dark:text-stone-400">
            <p>{formatDate(post.frontmatter.publishDate)}</p>
            {(hasViews || hasComments) && (
              <div class="flex items-center gap-3">
                {hasViews && (
                  <span class="flex items-center gap-1">
                    <SvgIcon name="eye" className="h-3.5 w-3.5" />
                    {viewsCount.toLocaleString('ru-RU')}
                  </span>
                )}
                {hasComments && (
                  <span class="flex items-center gap-1">
                    <SvgIcon name="comment" className="h-3.5 w-3.5" />
                    {commentsCount.toLocaleString('ru-RU')}
                  </span>
                )}
              </div>
            )}
          </div>

          {postTags.length > 0 && (
            <div class="pb-4">
              <Tags tags={postTags} />
            </div>
          )}

          <p class="line-clamp-6 whitespace-pre-wrap text-sm leading-relaxed">{textPreview}</p>
        </div>

        {hasReactions && (
          <div class="mt-4 flex justify-end">
            <TelegramReactions
              reactions={reactions}
              className="text-xs"
            />
          </div>
        )}

        <p class="mt-4 text-sm underline">Читать далее →</p>
      </div>
    </div>
  </div>
</a>
