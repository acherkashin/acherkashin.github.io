---
interface Props {
  media: string[];
  alt?: string;
  mode?: 'grid' | 'carousel';
}

const { media, alt = 'Telegram post media', mode = 'grid' } = Astro.props;

if (!media || media.length === 0) {
  return null;
}

// Smart grid layout calculator (Telegram-style)
const calculateGridLayout = (count: number): number[] => {
  if (count === 1) return [1];
  if (count === 2) return [2];
  if (count === 3) return [3];
  if (count === 4) return [2, 2];
  if (count === 5) return [2, 3];
  if (count === 6) return [3, 3];
  if (count === 7) return [2, 2, 3];
  if (count === 8) return [2, 3, 3];
  if (count === 9) return [3, 3, 3];
  if (count === 10) return [3, 4, 3]; // 3 in 1st row, 4 in 2nd, 3 in 3rd
  // For more than 10, use pattern: start with 3s, then balance
  const rows = Math.ceil(count / 3);
  const layout: number[] = [];
  let remaining = count;
  for (let i = 0; i < rows; i++) {
    if (remaining >= 3) {
      layout.push(3);
      remaining -= 3;
    } else {
      layout.push(remaining);
      remaining = 0;
    }
  }
  return layout;
};

const gridLayout = calculateGridLayout(media.length);

const isVideo = (src: string) => {
  return src.match(/\.(mp4|webm|ogg)$/i);
};

// Build rows based on layout
const buildRows = () => {
  const rows: string[][] = [];
  let index = 0;
  for (const rowSize of gridLayout) {
    rows.push(media.slice(index, index + rowSize));
    index += rowSize;
  }
  return rows;
};

const rows = buildRows();
---

{mode === 'grid' ? (
  <!-- Smart Grid Layout -->
  <div class="flex flex-col gap-2" id="telegram-media-gallery">
    {rows.map((row, rowIndex) => (
      <div class={`grid gap-2 grid-cols-${row.length}`} style={`grid-template-columns: repeat(${row.length}, minmax(0, 1fr))`}>
        {row.map((src, colIndex) => {
          const mediaIndex = gridLayout.slice(0, rowIndex).reduce((a, b) => a + b, 0) + colIndex;
          return (
            <div class="relative overflow-hidden rounded-lg aspect-square bg-stone-200 dark:bg-stone-800">
              {isVideo(src) ? (
                <video
                  src={src}
                  controls
                  class="h-full w-full object-cover"
                  preload="metadata"
                >
                  <track kind="captions" />
                </video>
              ) : (
                <button
                  class="lightbox-trigger h-full w-full cursor-zoom-in"
                  data-index={mediaIndex}
                  type="button"
                  aria-label={`View image ${mediaIndex + 1}`}
                >
                  <img
                    src={src}
                    alt={`${alt} ${mediaIndex + 1}`}
                    class="h-full w-full object-cover transition-transform hover:scale-105"
                    loading="lazy"
                  />
                </button>
              )}
            </div>
          );
        })}
      </div>
    ))}
  </div>

  <!-- Lightbox Modal -->
  <div 
    id="image-lightbox" 
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95 p-4"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
  >
    <button
      id="close-lightbox"
      class="absolute right-4 top-4 z-10 rounded-full bg-white/10 p-2 text-white hover:bg-white/20"
      aria-label="Close"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex h-full w-full flex-col">
      <!-- Main Image -->
      <div class="flex flex-1 items-center justify-center">
        <img
          id="lightbox-image"
          src=""
          alt=""
          class="max-h-full max-w-full object-contain"
        />
      </div>

      <!-- Thumbnails -->
      {media.filter(src => !isVideo(src)).length > 1 && (
        <div class="mt-4 flex justify-center gap-2 overflow-x-auto pb-4">
          {media.map((src, index) => (
            !isVideo(src) && (
              <button
                class="lightbox-thumb h-16 w-16 flex-shrink-0 overflow-hidden rounded border-2 border-transparent hover:border-white"
                data-index={index}
                type="button"
              >
                <img
                  src={src}
                  alt={`Thumbnail ${index + 1}`}
                  class="h-full w-full object-cover"
                />
              </button>
            )
          ))}
        </div>
      )}
    </div>
  </div>
) : (
  <!-- Carousel Layout (Alternative) -->
  <div class="relative">
    <div class="carousel-container overflow-x-auto snap-x snap-mandatory">
      <div class="flex gap-2">
        {media.map((src, index) => (
          <div class="carousel-item min-w-full snap-center">
            <div class="relative overflow-hidden rounded-lg">
              {isVideo(src) ? (
                <video
                  src={src}
                  controls
                  class="h-full w-full object-cover"
                  preload="metadata"
                >
                  <track kind="captions" />
                </video>
              ) : (
                <img
                  src={src}
                  alt={`${alt} ${index + 1}`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
    
    {media.length > 1 && (
      <div class="mt-2 flex justify-center gap-1.5">
        {media.map((_, index) => (
          <button
            class="carousel-dot h-2 w-2 rounded-full bg-stone-400 transition-all hover:bg-stone-600 dark:bg-stone-600 dark:hover:bg-stone-400"
            data-index={index}
            aria-label={`Go to slide ${index + 1}`}
          />
        ))}
      </div>
    )}
  </div>
)}

<style>
  .carousel-container {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  
  .carousel-container::-webkit-scrollbar {
    display: none;
  }
  
  .carousel-dot.active {
    @apply bg-stone-800 dark:bg-stone-200 scale-125;
  }

  .lightbox-thumb.active {
    @apply border-white;
  }

  #image-lightbox.show {
    display: flex;
  }
</style>

<script>
  // Carousel functionality (only if carousel mode is used)
  const container = document.querySelector('.carousel-container');
  const dots = document.querySelectorAll('.carousel-dot');
  
  if (container && dots.length > 0) {
    const updateActiveDot = () => {
      const scrollLeft = container.scrollLeft;
      const itemWidth = container.scrollWidth / dots.length;
      const activeIndex = Math.round(scrollLeft / itemWidth);
      
      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    };
    
    container.addEventListener('scroll', updateActiveDot);
    
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        const itemWidth = container.scrollWidth / dots.length;
        container.scrollTo({
          left: itemWidth * index,
          behavior: 'smooth'
        });
      });
    });
    
    updateActiveDot();
  }

  // Lightbox functionality
  const lightbox = document.getElementById('image-lightbox');
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
  const closeLightbox = document.getElementById('close-lightbox');
  const triggers = document.querySelectorAll('.lightbox-trigger');
  const thumbs = document.querySelectorAll('.lightbox-thumb');
  const gallery = document.getElementById('telegram-media-gallery');

  if (lightbox && lightboxImage && gallery) {
    const images: string[] = [];
    
    // Collect all image sources
    gallery.querySelectorAll('img').forEach(img => {
      if (img.src) images.push(img.src);
    });

    let currentIndex = 0;

    const showImage = (index: number) => {
      if (index >= 0 && index < images.length) {
        currentIndex = index;
        lightboxImage.src = images[index];
        lightboxImage.alt = `Image ${index + 1} of ${images.length}`;
        
        // Update active thumbnail
        thumbs.forEach((thumb, i) => {
          const thumbIndex = parseInt(thumb.getAttribute('data-index') || '0');
          if (thumbIndex === index) {
            thumb.classList.add('active');
          } else {
            thumb.classList.remove('active');
          }
        });
      }
    };

    const openLightbox = (index: number) => {
      showImage(index);
      lightbox.classList.add('show');
      document.body.style.overflow = 'hidden';
    };

    const closeLightboxFn = () => {
      lightbox.classList.remove('show');
      document.body.style.overflow = '';
    };

    // Open lightbox on trigger click
    triggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        const index = parseInt(trigger.getAttribute('data-index') || '0');
        openLightbox(index);
      });
    });

    // Thumbnail navigation
    thumbs.forEach(thumb => {
      thumb.addEventListener('click', () => {
        const index = parseInt(thumb.getAttribute('data-index') || '0');
        showImage(index);
      });
    });

    // Close button
    closeLightbox?.addEventListener('click', closeLightboxFn);

    // Click outside to close
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        closeLightboxFn();
      }
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('show')) return;

      if (e.key === 'Escape') {
        closeLightboxFn();
      } else if (e.key === 'ArrowLeft') {
        showImage(currentIndex - 1);
      } else if (e.key === 'ArrowRight') {
        showImage(currentIndex + 1);
      }
    });
  }
</script>