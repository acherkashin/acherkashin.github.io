---
interface Props {
  media: string[];
  alt?: string;
  mode?: 'grid' | 'carousel';
}

const { media, alt = 'Telegram post media', mode = 'grid' } = Astro.props;

if (!media || media.length === 0) {
  return null;
}

// Smart grid layout calculator (Telegram-style)
const calculateGridLayout = (count: number): number[] => {
  if (count === 1) return [1];
  if (count === 2) return [2];
  if (count === 3) return [3];
  if (count === 4) return [2, 2];
  if (count === 5) return [2, 3];
  if (count === 6) return [3, 3];
  if (count === 7) return [2, 2, 3];
  if (count === 8) return [2, 3, 3];
  if (count === 9) return [3, 3, 3];
  if (count === 10) return [3, 4, 3]; // 3 in 1st row, 4 in 2nd, 3 in 3rd
  // For more than 10, use pattern: start with 3s, then balance
  const rows = Math.ceil(count / 3);
  const layout: number[] = [];
  let remaining = count;
  for (let i = 0; i < rows; i++) {
    if (remaining >= 3) {
      layout.push(3);
      remaining -= 3;
    } else {
      layout.push(remaining);
      remaining = 0;
    }
  }
  return layout;
};

const gridLayout = calculateGridLayout(media.length);

const isVideo = (src: string) => {
  return src.match(/\.(mp4|webm|ogg)$/i);
};

// Build rows based on layout
const buildRows = () => {
  const rows: string[][] = [];
  let index = 0;
  for (const rowSize of gridLayout) {
    rows.push(media.slice(index, index + rowSize));
    index += rowSize;
  }
  return rows;
};

const rows = buildRows();
const isSingleMedia = media.length === 1;

// Serialize media array for JavaScript
const mediaJson = JSON.stringify(media);
---

{mode === 'grid' ? (
  <!-- Smart Grid Layout -->
  <div class="flex flex-col gap-2" id="telegram-media-gallery" data-media={mediaJson}>
    {rows.map((row, rowIndex) => (
      <div class={`grid gap-2 grid-cols-${row.length}`} style={`grid-template-columns: repeat(${row.length}, minmax(0, 1fr))`}>
        {row.map((src, colIndex) => {
          const mediaIndex = gridLayout.slice(0, rowIndex).reduce((a, b) => a + b, 0) + colIndex;
          return (
            <div class={`relative overflow-hidden rounded-lg bg-stone-200 dark:bg-stone-800 ${isSingleMedia ? 'flex min-h-[14rem] items-center justify-center' : 'aspect-square'}`}>
              {isVideo(src) ? (
                <video
                  src={src}
                  controls
                  class={`h-full w-full ${isSingleMedia ? 'object-contain' : 'object-cover'}`}
                  preload="metadata"
                >
                  <track kind="captions" />
                </video>
              ) : (
                <button
                  class="lightbox-trigger h-full w-full cursor-zoom-in"
                  data-index={mediaIndex}
                  data-type="image"
                  type="button"
                  aria-label={`View image ${mediaIndex + 1}`}
                >
                  <img
                    src={src}
                    alt={`${alt} ${mediaIndex + 1}`}
                    class={`h-full w-full ${isSingleMedia ? 'object-contain' : 'object-cover transition-transform hover:scale-105'}`}
                    loading="lazy"
                  />
                </button>
              )}
            </div>
          );
        })}
      </div>
    ))}
  </div>

  <!-- Lightbox Modal -->
  <div 
    id="image-lightbox" 
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
  >
    <button
      id="close-lightbox"
      class="absolute right-2 top-2 z-10 rounded-full bg-white/10 p-2 text-white hover:bg-white/20"
      aria-label="Close"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex h-full w-full flex-col gap-2 p-2 pt-14">
      <!-- Main Media Container -->
      <div class="flex flex-1 items-center justify-center overflow-hidden min-h-0">
        <div id="lightbox-media-container" class="max-h-full max-w-full flex">
          <!-- Media will be dynamically inserted here -->
        </div>
      </div>

      <!-- Thumbnails -->
      {media.length > 1 && (
        <div class="flex justify-center gap-2 overflow-x-auto pb-2 flex-shrink-0">
          {media.map((src, index) => (
            <button
              class="lightbox-thumb h-16 w-16 flex-shrink-0 overflow-hidden rounded border-2 border-transparent hover:border-white relative"
              data-index={index}
              type="button"
              aria-label={`View media ${index + 1}`}
            >
              {isVideo(src) ? (
                <>
                  <video
                    src={src}
                    class="h-full w-full object-cover pointer-events-none"
                    preload="metadata"
                  >
                    <track kind="captions" />
                  </video>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="h-6 w-6 text-white drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </>
              ) : (
                <img
                  src={src}
                  alt={`Thumbnail ${index + 1}`}
                  class="h-full w-full object-cover"
                />
              )}
            </button>
          ))}
        </div>
      )}
    </div>
  </div>
) : (
  <!-- Carousel Layout (Alternative) -->
  <div class="relative">
    <div class="carousel-container overflow-x-auto snap-x snap-mandatory">
      <div class="flex gap-2">
        {media.map((src, index) => (
          <div class="carousel-item min-w-full snap-center">
            <div class="relative overflow-hidden rounded-lg">
              {isVideo(src) ? (
                <button
                  class="lightbox-trigger h-full w-full cursor-pointer relative"
                  data-index={index}
                  data-type="video"
                  type="button"
                  aria-label={`View video ${index + 1}`}
                >
                  <video
                    src={src}
                    class="h-full w-full object-cover pointer-events-none"
                    preload="metadata"
                  >
                    <track kind="captions" />
                  </video>
                  <div class="absolute inset-0 flex items-center justify-center bg-black/20 hover:bg-black/30 transition-colors">
                    <svg class="h-16 w-16 text-white drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </button>
              ) : (
                <img
                  src={src}
                  alt={`${alt} ${index + 1}`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
    
    {media.length > 1 && (
      <div class="mt-2 flex justify-center gap-1.5">
        {media.map((_, index) => (
          <button
            class="carousel-dot h-2 w-2 rounded-full bg-stone-400 transition-all hover:bg-stone-600 dark:bg-stone-600 dark:hover:bg-stone-400"
            data-index={index}
            aria-label={`Go to slide ${index + 1}`}
          />
        ))}
      </div>
    )}
  </div>
)}

<style>
  .carousel-container {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  
  .carousel-container::-webkit-scrollbar {
    display: none;
  }
  
  .carousel-dot.active {
    @apply bg-stone-800 dark:bg-stone-200 scale-125;
  }

  .lightbox-thumb.active {
    @apply border-white;
  }

  #image-lightbox.show {
    display: flex;
  }
</style>

<script>
  // Track if lightbox has been initialized to prevent duplicates
  let lightboxInitialized = false;

  // Carousel functionality (only if carousel mode is used)
  function initializeCarousel() {
    const container = document.querySelector('.carousel-container');
    const dots = document.querySelectorAll('.carousel-dot');
    
    if (!container || dots.length === 0) return;
    
    const updateActiveDot = () => {
      const scrollLeft = container.scrollLeft;
      const itemWidth = container.scrollWidth / dots.length;
      const activeIndex = Math.round(scrollLeft / itemWidth);
      
      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    };
    
    container.addEventListener('scroll', updateActiveDot);
    
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        const itemWidth = container.scrollWidth / dots.length;
        container.scrollTo({
          left: itemWidth * index,
          behavior: 'smooth'
        });
      });
    });
    
    updateActiveDot();
  }

  // Lightbox functionality
  function initializeLightbox() {
    const gallery = document.getElementById('telegram-media-gallery');

    // Exit if gallery doesn't exist or already initialized
    if (!gallery || lightboxInitialized) return;
    
    // Mark as initialized
    lightboxInitialized = true;

    // Get media array from data attribute
    const mediaData = gallery.getAttribute('data-media');
    if (!mediaData) return;
    
    const media: string[] = JSON.parse(mediaData);
    
    // If no media found, exit
    if (media.length === 0) return;

    let currentIndex = 0;

    const isVideo = (src: string) => {
      return src.match(/\.(mp4|webm|ogg)$/i);
    };

    const showMedia = (index: number) => {
      if (index >= 0 && index < media.length) {
        currentIndex = index;
        
        const container = document.getElementById('lightbox-media-container');
        if (!container) return;
        
        const src = media[index];
        if (!src) return;

        const mediaType = isVideo(src) ? 'video' : 'image';
        
        // Clear container and create new element
        container.innerHTML = '';
        
        if (mediaType === 'video') {
          const video = document.createElement('video');
          video.src = src;
          video.controls = true;
          video.autoplay = true;
          video.className = 'max-h-full max-w-full object-contain';
          const track = document.createElement('track');
          track.kind = 'captions';
          video.appendChild(track);
          container.appendChild(video);
        } else {
          const img = document.createElement('img');
          img.src = src;
          img.alt = `Media ${index + 1} of ${media.length}`;
          img.className = 'max-h-full max-w-full object-contain';
          container.appendChild(img);
        }
        
        // Update active thumbnail
        const thumbs = document.querySelectorAll('.lightbox-thumb');
        thumbs.forEach((thumb) => {
          const thumbIndex = parseInt(thumb.getAttribute('data-index') || '0');
          if (thumbIndex === index) {
            thumb.classList.add('active');
          } else {
            thumb.classList.remove('active');
          }
        });
      }
    };

    const openLightbox = (index: number) => {
      const lightbox = document.getElementById('image-lightbox');
      if (!lightbox) return;
      
      showMedia(index);
      lightbox.classList.add('show');
      document.body.style.overflow = 'hidden';
    };

    const closeLightboxFn = () => {
      const lightbox = document.getElementById('image-lightbox');
      if (!lightbox) return;
      
      lightbox.classList.remove('show');
      document.body.style.overflow = '';
    };

    // Attach event listeners to triggers
    const triggers = document.querySelectorAll('.lightbox-trigger');
    triggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        const index = parseInt(trigger.getAttribute('data-index') || '0');
        openLightbox(index);
      });
    });

    // Thumbnail navigation
    const thumbs = document.querySelectorAll('.lightbox-thumb');
    thumbs.forEach(thumb => {
      thumb.addEventListener('click', () => {
        const index = parseInt(thumb.getAttribute('data-index') || '0');
        showMedia(index);
      });
    });

    // Close button - query fresh
    const closeLightboxBtn = document.getElementById('close-lightbox');
    closeLightboxBtn?.addEventListener('click', closeLightboxFn);

    // Click outside to close - query fresh
    const lightbox = document.getElementById('image-lightbox');
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        closeLightboxFn();
      }
    });

    // Keyboard navigation
    const keyboardHandler = (e: KeyboardEvent) => {
      const lightbox = document.getElementById('image-lightbox');
      if (!lightbox || !lightbox.classList.contains('show')) return;

      if (e.key === 'Escape') {
        closeLightboxFn();
      } else if (e.key === 'ArrowLeft') {
        showMedia(currentIndex - 1);
      } else if (e.key === 'ArrowRight') {
        showMedia(currentIndex + 1);
      }
    };

    document.addEventListener('keydown', keyboardHandler);
  }

  // Initialize on DOMContentLoaded for first page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initializeCarousel();
      initializeLightbox();
    });
  } else {
    initializeCarousel();
    initializeLightbox();
  }

  // Reinitialize after Astro page transitions
  document.addEventListener('astro:after-swap', () => {
    // Reset initialization flag for new page
    lightboxInitialized = false;
    initializeCarousel();
    initializeLightbox();
  });
</script>
