---
import Section from './Section.astro';

const navigationItems = [
	{
		label: 'RSS',
		href: '/rss.xml',
		ariaLabel: 'RSS лента',
		reload: true,
		icon: 'rss'
	},
	{ label: 'Посты', href: '/posts' },
	{ label: 'Демо', href: '/demos' },
	{ label: 'Теги', href: '/tags' },
	{ label: 'Блог', href: '/' },
	{
		label: 'Сетка',
		href: 'https://set.ki/channel/LWuJgdL',
		ariaLabel: 'Профиль в Сетке',
		external: true,
		icon: 'setka'
	}
];

const desktopNavigationItems = navigationItems.filter((item) => item.label !== 'Сетка');
const mobileNavigationItems = navigationItems;
---

<Section>
	<div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
		<div class="flex items-center justify-between gap-3">
			<a
				href="/"
				class="inline-flex min-w-0 items-center gap-2 whitespace-nowrap text-[1.75rem] font-bold leading-none text-gray-950 dark:text-white md:text-3xl"
			>
				<img
					id="blog-logo"
					class="inline-block h-10 w-10 rounded-full md:h-12 md:w-12"
					src="/logo.png"
					alt="cherkashin.dev logo"
					width="48"
					height="48"
					style="width:48px;height:48px"
				/>
				<script is:inline>
					function applySeasonalLogo() {
						const logo = document.getElementById('blog-logo');
						if (!logo) return;

						const season = document.documentElement.dataset.season;
						logo.setAttribute(
							'src',
							season === 'new-year' ? '/new-year-logo.webp' : '/logo.png'
						);
					}

					document.addEventListener('astro:after-swap', applySeasonalLogo);
					applySeasonalLogo();
				</script>
				<span class="hidden text-[1.55rem] text-gray-500 md:inline md:pr-2 md:text-2xl">{'{'}</span>cherkashin<span
					class="text-orange-600">.</span
				>dev<span class="hidden text-[1.55rem] text-gray-500 md:inline md:pl-2 md:text-2xl">{'}'}</span></a
			>
			<div class="flex items-center md:hidden">
				<div class="flex flex-col justify-center">
					<input type="checkbox" id="light-switch-mobile" class="light-switch sr-only" />
					<label class="tada relative cursor-pointer p-2" for="light-switch-mobile">
						<svg class="dark:hidden" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
							<path
								class="fill-stone-800"
								d="M7 0h2v2H7zM12.88 1.637l1.414 1.415-1.415 1.413-1.413-1.414zM14 7h2v2h-2zM12.95 14.433l-1.414-1.413 1.413-1.415 1.415 1.414zM7 14h2v2H7zM2.98 14.364l-1.413-1.415 1.414-1.414 1.414 1.415zM0 7h2v2H0zM3.05 1.706 4.463 3.12 3.05 4.535 1.636 3.12z"
							></path>
							<path class="fill-gray-900" d="M8 4C5.8 4 4 5.8 4 8s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4Z"
							></path>
						</svg>
						<svg class="hidden dark:block" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
							<path
								class="fill-slate-400"
								d="M6.2 1C3.2 1.8 1 4.6 1 7.9 1 11.8 4.2 15 8.1 15c3.3 0 6-2.2 6.9-5.2C9.7 11.2 4.8 6.3 6.2 1Z"
							></path>
							<path
								class="fill-slate-500"
								d="M12.5 5a.625.625 0 0 1-.625-.625 1.252 1.252 0 0 0-1.25-1.25.625.625 0 1 1 0-1.25 1.252 1.252 0 0 0 1.25-1.25.625.625 0 1 1 1.25 0c.001.69.56 1.249 1.25 1.25a.625.625 0 1 1 0 1.25c-.69.001-1.249.56-1.25 1.25A.625.625 0 0 1 12.5 5Z"
							></path>
						</svg>
						<span class="sr-only">Перелючиться на светлую или тёмную тему</span>
					</label>
				</div>
			</div>
		</div>
		<div class="hidden items-center gap-3 md:flex">
			<nav aria-label="Основная навигация">
				<ul class="flex flex-row items-center">
					{
						desktopNavigationItems.map((item) => (
							<li>
								<a
									href={item.href}
									data-astro-reload={item.reload ? true : undefined}
									aria-label={item.ariaLabel}
									class="mr-3 inline-flex items-center gap-1 hover:text-orange-600"
								>
									{item.icon === 'rss' && (
										<svg
											class="h-4 w-4"
											width="16"
											height="16"
											viewBox="0 0 24 24"
											fill="currentColor"
											aria-hidden="true"
										>
											<circle cx="6.18" cy="17.82" r="2.18"></circle>
											<path d="M4 11a9 9 0 0 1 9 9H9a5 5 0 0 0-5-5v-4z"></path>
											<path d="M4 4a16 16 0 0 1 16 16h-4A12 12 0 0 0 4 8V4z"></path>
										</svg>
									)}
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
			<a
				href="https://set.ki/channel/LWuJgdL"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Профиль в Сетке"
				class="inline-flex items-center gap-2 rounded-full border border-stone-300/80 bg-white/80 px-3 py-2 text-sm font-medium text-gray-900 transition hover:border-orange-500 hover:text-orange-600 dark:border-stone-700 dark:bg-stone-800/80 dark:text-white"
			>
				<img
					src="/social-icons/setka-logo.svg"
					alt=""
					width="20"
					height="20"
					class="h-5 w-5 shrink-0"
					aria-hidden="true"
				/>
				<span>Сетка</span>
			</a>
			<div class="flex flex-col justify-center">
				<input type="checkbox" id="light-switch-desktop" class="light-switch sr-only" />
				<label class="tada relative cursor-pointer p-2" for="light-switch-desktop">
					<svg class="dark:hidden" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
						<path
							class="fill-stone-800"
							d="M7 0h2v2H7zM12.88 1.637l1.414 1.415-1.415 1.413-1.413-1.414zM14 7h2v2h-2zM12.95 14.433l-1.414-1.413 1.413-1.415 1.415 1.414zM7 14h2v2H7zM2.98 14.364l-1.413-1.415 1.414-1.414 1.414 1.415zM0 7h2v2H0zM3.05 1.706 4.463 3.12 3.05 4.535 1.636 3.12z"
						></path>
						<path class="fill-gray-900" d="M8 4C5.8 4 4 5.8 4 8s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4Z"
						></path>
					</svg>
					<svg class="hidden dark:block" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
						<path
							class="fill-slate-400"
							d="M6.2 1C3.2 1.8 1 4.6 1 7.9 1 11.8 4.2 15 8.1 15c3.3 0 6-2.2 6.9-5.2C9.7 11.2 4.8 6.3 6.2 1Z"
						></path>
						<path
							class="fill-slate-500"
							d="M12.5 5a.625.625 0 0 1-.625-.625 1.252 1.252 0 0 0-1.25-1.25.625.625 0 1 1 0-1.25 1.252 1.252 0 0 0 1.25-1.25.625.625 0 1 1 1.25 0c.001.69.56 1.249 1.25 1.25a.625.625 0 1 1 0 1.25c-.69.001-1.249.56-1.25 1.25A.625.625 0 0 1 12.5 5Z"
						></path>
					</svg>
					<span class="sr-only">Перелючиться на светлую или тёмную тему</span>
				</label>
			</div>
		</div>
		<nav aria-label="Основная навигация" class="md:hidden">
			<ul class="flex flex-wrap gap-2">
				{
					mobileNavigationItems.map((item) => (
						<li>
							<a
								href={item.href}
								target={item.external ? '_blank' : undefined}
								rel={item.external ? 'noopener noreferrer' : undefined}
								data-astro-reload={item.reload ? true : undefined}
								aria-label={item.ariaLabel}
								class="inline-flex items-center gap-2 rounded-full border border-stone-300/80 bg-white/80 px-3 py-2 text-sm font-medium text-gray-900 transition hover:border-orange-500 hover:text-orange-600 dark:border-stone-700 dark:bg-stone-800/80 dark:text-white"
							>
								{item.icon === 'rss' && (
									<svg
										class="h-4 w-4 shrink-0"
										width="16"
										height="16"
										viewBox="0 0 24 24"
										fill="currentColor"
										aria-hidden="true"
									>
										<circle cx="6.18" cy="17.82" r="2.18"></circle>
										<path d="M4 11a9 9 0 0 1 9 9H9a5 5 0 0 0-5-5v-4z"></path>
										<path d="M4 4a16 16 0 0 1 16 16h-4A12 12 0 0 0 4 8V4z"></path>
									</svg>
								)}
								{item.icon === 'setka' && (
									<img
										src="/social-icons/setka-logo.svg"
										alt=""
										width="20"
										height="20"
										class="h-4 w-4 shrink-0"
										aria-hidden="true"
									/>
								)}
								<span>{item.label}</span>
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</Section>

<script>
	document.addEventListener('astro:page-load', () => {
		const lightSwitches = document.querySelectorAll('.light-switch');
		if (lightSwitches.length > 0) {
			lightSwitches.forEach((lightSwitch: any, i) => {
				if (localStorage.getItem('dark-mode') === 'true') {
					lightSwitch.checked = true;
				}
				lightSwitch.addEventListener('click', () => {
					const { checked } = lightSwitch;
					lightSwitches.forEach((el: any, n) => {
						if (n !== i) {
							el.checked = checked;
						}
					});
					if (lightSwitch.checked) {
						document.documentElement.classList.add('dark');
						localStorage.setItem('dark-mode', 'true');
					} else {
						document.documentElement.classList.remove('dark');
						localStorage.setItem('dark-mode', 'false');
					}
				});
			});
		}
	});
</script>
