---
import Section from './Section.astro';
import TelegramPostCard from './TelegramPostCard.astro';

interface Props {
  posts: any[];
}

const { posts } = Astro.props;
const VIDEO_MEDIA_RE = /\.(mp4|mov|webm|m4v|ogg)(?:[?#].*)?$/i;

let imageIndex = 0;
const postsWithImagePriority = posts.map((post: any) => {
  const mediaList = Array.isArray(post.frontmatter.media) ? post.frontmatter.media : [];
  const hasArchiveImage =
    typeof post.frontmatter?.archiveImage?.src === 'string' ||
    mediaList.some((src: string) => !VIDEO_MEDIA_RE.test(src));

  return {
    post,
    imageIndex: hasArchiveImage ? imageIndex++ : Number.POSITIVE_INFINITY,
  };
});
---

<Section>
  <div class="flex justify-between pb-4">
    <p class="text-xl font-bold">Посты</p>
    <a href="/posts" class="underline hover:text-orange-600">Все посты →</a>
  </div>
  <div class="flex flex-col pb-4 md:flex-row">
    {postsWithImagePriority.map(({ post, imageIndex }: any) => (
      <div class="mb-4 basis-1 last:mr-0 md:mr-4 md:basis-1/3">
        <TelegramPostCard post={post} index={imageIndex} />
      </div>
    ))}
  </div>
</Section>
