---
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import PostContent from '@/components/PostContent.astro';
import TelegramMediaGallery from '@/components/TelegramMediaGallery.astro';
import TelegramReactions from '@/components/TelegramReactions.astro';
import TelegramImageLightbox from '@/components/TelegramImageLightbox.astro';
import ShareButton from '@/components/ShareButton.astro';
import Tags from '@/components/Tags.astro';
import { formatDate } from '@/utils/data.util';
import { extractTelegramTagsFromMarkdown } from '@/utils/telegram-tags.util';

const { frontmatter, rawContent, compiledContent } = Astro.props;

const formattedDate = formatDate(frontmatter.publishDate);
const formattedEditDate = frontmatter.updatedDate ? formatDate(frontmatter.updatedDate) : null;
const rawPostContent = typeof rawContent === 'function' ? rawContent() : '';
const postTags = extractTelegramTagsFromMarkdown(rawPostContent);
const compiledPostContent = typeof compiledContent === 'function' ? await compiledContent() : '';
const channelSlug = typeof frontmatter.channel === 'string'
  ? frontmatter.channel.replace(/^@/, '').trim()
  : '';
const telegramId = Number(frontmatter.telegramId);
const fallbackTelegramId = Number(
  Array.isArray(frontmatter.telegramMessageIds) ? frontmatter.telegramMessageIds[0] : NaN
);
const telegramPostId = Number.isFinite(telegramId)
  ? telegramId
  : Number.isFinite(fallbackTelegramId)
    ? fallbackTelegramId
    : null;
const telegramPostUrl = channelSlug && telegramPostId !== null
  ? `https://t.me/${channelSlug}/${telegramPostId}`
  : null;
const viewsCount = Number(frontmatter.views);
const hasViews = Number.isFinite(viewsCount) && viewsCount > 0;
const commentsCount = Number(frontmatter.comments);
const hasComments =
  frontmatter.comments !== null &&
  frontmatter.comments !== undefined &&
  Number.isFinite(commentsCount);
const hasHeaderMetrics = hasViews || hasComments;
const hasReactions =
  Array.isArray(frontmatter.reactions) && frontmatter.reactions.length > 0;

const HASHTAG_ONLY_PARAGRAPH_RE = /^(?:#[\p{L}\p{N}_]+(?:\s+|$))+$/u;

const removeHashtagOnlyParagraphs = (html: string): string => {
  if (!html) return html;

  return html.replace(/<p>([\s\S]*?)<\/p>/g, (paragraphHtml, innerHtml) => {
    const plainText = String(innerHtml)
      .replace(/<[^>]*>/g, '')
      .replace(/&nbsp;/g, ' ')
      .trim();

    return HASHTAG_ONLY_PARAGRAPH_RE.test(plainText) ? '' : paragraphHtml;
  });
};

const cleanedPostContent = removeHashtagOnlyParagraphs(compiledPostContent);
---

<Base head={{ title: frontmatter.title, description: frontmatter.title }}>
  <TelegramImageLightbox />
  <div id="content" class="mx-auto w-full max-w-screen-md">
    <Section>
      <div class="flex flex-col">
        <!-- Header -->
        <div class="mb-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs text-stone-600 dark:text-stone-400">
                {formattedDate}
                {formattedEditDate && (
                  <span class="ml-2">
                    (изменено: {formattedEditDate})
                  </span>
                )}
              </p>
              {frontmatter.channel && (
                <p class="mt-1 text-xs font-medium text-stone-700 dark:text-stone-300">
                  Канал: <a 
                    href={`https://t.me/${channelSlug}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-orange-700 hover:underline dark:text-orange-500"
                  >
                    {frontmatter.channel}
                  </a>
                </p>
              )}
            </div>
            {(hasHeaderMetrics || telegramPostUrl) && (
              <div class="ml-auto flex items-center justify-end gap-3 text-xs text-stone-600 dark:text-stone-400">
                {hasViews && (
                  <span class="flex items-center gap-1">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    <span>{viewsCount.toLocaleString('ru-RU')}</span>
                  </span>
                )}
                {hasComments && (
                  <span class="flex items-center gap-1">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h8M8 14h5m-9 7 3.674-3.674A1 1 0 018.38 17H19a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 001 1.732V21z" />
                    </svg>
                    <span>{commentsCount.toLocaleString('ru-RU')}</span>
                  </span>
                )}
                {telegramPostUrl && (
                  <a
                    href={telegramPostUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Открыть пост в Telegram"
                    title="Открыть пост в Telegram"
                    class="inline-flex items-center text-orange-700 hover:underline dark:text-orange-500"
                  >
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2 11 13" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2 15 22 11 13 2 9 22 2z" />
                    </svg>
                  </a>
                )}
              </div>
            )}
          </div>
          {postTags.length > 0 && (
            <div class="mt-3">
              <Tags tags={postTags} withHref={true} />
            </div>
          )}
        </div>

        <!-- Media Gallery -->
        {frontmatter.media && frontmatter.media.length > 0 && (
          <div class="mb-6">
            <TelegramMediaGallery 
              media={frontmatter.media} 
              alt={frontmatter.title}
              mode="grid"
            />
            <!-- To switch to carousel mode, change mode="grid" to mode="carousel" above -->
          </div>
        )}

        <!-- Post Content -->
        <PostContent>
          <div class="telegram-content">
            {cleanedPostContent ? <Fragment set:html={cleanedPostContent} /> : <slot />}
          </div>
        </PostContent>

        <!-- Reactions and Share -->
        <Section>
          <div class="flex items-center justify-end gap-3 border-t border-stone-300 pt-4 dark:border-stone-700">
            {hasReactions && (
              <TelegramReactions
                reactions={frontmatter.reactions || []}
              />
            )}
            <ShareButton title={frontmatter.title} count={frontmatter.forwards} />
          </div>
        </Section>
      </div>
    </Section>
  </div>
</Base>

<style is:global>
.telegram-content p {
  white-space: pre-wrap;
}
</style>
