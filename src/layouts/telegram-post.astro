---
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import PostContent from '@/components/PostContent.astro';
import TelegramMediaGallery from '@/components/TelegramMediaGallery.astro';
import TelegramReactions from '@/components/TelegramReactions.astro';
import TelegramImageLightbox from '@/components/TelegramImageLightbox.astro';
import { formatDate } from '@/utils/data.util';

const { frontmatter } = Astro.props;

const formattedDate = formatDate(frontmatter.publishDate);
const formattedEditDate = frontmatter.updatedDate ? formatDate(frontmatter.updatedDate) : null;
---

<Base head={{ title: frontmatter.title, description: frontmatter.title }}>
  <TelegramImageLightbox />
  <div id="content" class="mx-auto w-full max-w-screen-md">
    <Section>
      <div class="flex flex-col">
        <!-- Header -->
        <div class="mb-4">
          <p class="text-xs text-stone-600 dark:text-stone-400">
            {formattedDate}
            {formattedEditDate && (
              <span class="ml-2">
                (изменено: {formattedEditDate})
              </span>
            )}
          </p>
          {frontmatter.channel && (
            <p class="mt-1 text-xs font-medium text-stone-700 dark:text-stone-300">
              Канал: <a 
                href={`https://t.me/${frontmatter.channel.replace('@', '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-orange-700 hover:underline dark:text-orange-500"
              >
                {frontmatter.channel}
              </a>
            </p>
          )}
        </div>

        <!-- Media Gallery -->
        {frontmatter.media && frontmatter.media.length > 0 && (
          <div class="mb-6">
            <TelegramMediaGallery 
              media={frontmatter.media} 
              alt={frontmatter.title}
              mode="grid"
            />
            <!-- To switch to carousel mode, change mode="grid" to mode="carousel" above -->
          </div>
        )}

        <!-- Post Content -->
        <PostContent>
          <div class="telegram-content whitespace-pre-wrap">
            <slot />
          </div>
        </PostContent>

        <!-- Reactions and Stats -->
        {(frontmatter.reactions?.length > 0 || frontmatter.views || frontmatter.forwards) && (
          <Section>
            <div class="flex justify-end border-t border-stone-300 pt-4 dark:border-stone-700">
              <TelegramReactions
                reactions={frontmatter.reactions || []}
                views={frontmatter.views}
                forwards={frontmatter.forwards}
              />
            </div>
          </Section>
        )}
      </div>
    </Section>
  </div>
</Base>

<style is:global>
  /* Telegram post content formatting (scoped under prose to override typography defaults) */
  .prose .telegram-content {
    line-height: 1.6;
  }

  .prose .telegram-content p {
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .prose .telegram-content p:first-child {
    margin-top: 0;
  }

  .prose .telegram-content p:last-child {
    margin-bottom: 0;
  }

  .prose .telegram-content ol,
  .prose .telegram-content ul {
    padding-left: 1.5rem;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
    list-style-position: outside;
  }

  .prose .telegram-content ol > li,
  .prose .telegram-content ul > li {
    padding-left: 0.5rem;
    margin-bottom: 0.5rem;
    /* Keep pre-wrap for paragraph text, but reset list items to avoid marker/text line split. */
    white-space: normal;
  }

  .prose .telegram-content ol > li:last-child,
  .prose .telegram-content ul > li:last-child {
    margin-bottom: 0;
  }

  .prose .telegram-content ol > li > p,
  .prose .telegram-content ul > li > p {
    margin-top: 0;
    margin-bottom: 0;
  }

  .prose .telegram-content ol ol,
  .prose .telegram-content ol ul,
  .prose .telegram-content ul ol,
  .prose .telegram-content ul ul {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .prose .telegram-content h1,
  .prose .telegram-content h2,
  .prose .telegram-content h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose .telegram-content h1:first-child,
  .prose .telegram-content h2:first-child,
  .prose .telegram-content h3:first-child {
    margin-top: 0;
  }
</style>
