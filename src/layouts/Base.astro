---
import Footer from '@/components/Footer.astro';
import Navbar from '@/components/Navbar.astro';
import { AppConfig } from '@/utils/AppConfig';
import {
	NEW_YEAR_END_DAY,
	NEW_YEAR_END_MONTH,
	NEW_YEAR_SEASON,
	SEASON_QUERY_NEW_YEAR_VALUE,
	SEASON_QUERY_PARAM,
	NEW_YEAR_START_DAY,
	NEW_YEAR_START_MONTH
} from '@/utils/newYearUtils';
import { YandexMetrika } from 'astro-yandex-metrika';
import { ClientRouter } from 'astro:transitions';

export interface Props {
	head: {
		title: string;
		description: string;
	};
}

const {
	head: { title, description }
} = Astro.props as Props;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content={AppConfig.author} />

		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="alternate" type="application/rss+xml" href="/rss.xml" />
		<link rel="icon" href="/favicon.png" />
		<ClientRouter />

		<script is:inline>
			function applyTheme() {
				if (
					localStorage.getItem('dark-mode') === 'true' ||
					(!('dark-mode' in localStorage) &&
						window.matchMedia('(prefers-color-scheme: dark)').matches)
				) {
					localStorage.setItem('dark-mode', 'true');
					document.querySelector('html')?.classList.add('dark');
				} else {
					localStorage.setItem('dark-mode', 'false');
					document.querySelector('html')?.classList.remove('dark');
				}
			}

			document.addEventListener('astro:after-swap', applyTheme);
			applyTheme();
		</script>
		<script
			is:inline
			define:vars={{
				newYearEndDay: NEW_YEAR_END_DAY,
				newYearEndMonth: NEW_YEAR_END_MONTH,
				newYearSeason: NEW_YEAR_SEASON,
				seasonQueryNewYearValue: SEASON_QUERY_NEW_YEAR_VALUE,
				seasonQueryParam: SEASON_QUERY_PARAM,
				newYearStartDay: NEW_YEAR_START_DAY,
				newYearStartMonth: NEW_YEAR_START_MONTH
			}}
		>
			function applySeason() {
				const searchParams = new URLSearchParams(window.location.search);
				const forcedSeason = searchParams.get(seasonQueryParam);
				const today = new Date();
				const month = today.getMonth();
				const day = today.getDate();
				const isDateBasedNewYear =
					(month === newYearStartMonth && day >= newYearStartDay) ||
					(month === newYearEndMonth && day <= newYearEndDay);
				const resolvedSeason =
					forcedSeason === seasonQueryNewYearValue
						? newYearSeason
						: isDateBasedNewYear
							? newYearSeason
							: null;

				if (resolvedSeason) {
					document.documentElement.dataset.season = resolvedSeason;
				} else {
					delete document.documentElement.dataset.season;
				}
			}

			document.addEventListener('astro:after-swap', applySeason);
			applySeason();
		</script>

		<YandexMetrika id="62071573" />
	</head>
	<body
		class="flex min-h-screen flex-col bg-stone-100 font-serif text-gray-950 dark:bg-stone-900 dark:text-white"
	>
		<Navbar />
		<div class="flex-1">
			<slot />
		</div>

		<Footer />
		<style is:global>
			:root {
			}
		</style>
	</body>
</html>
